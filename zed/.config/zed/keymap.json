// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Workspace",
    "bindings": {
      "cmd-;": "workspace::FocusCenterPane",
      // "shift shift": "file_finder::Toggle"
    },
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      // "j k": "vim::NormalBefore"
    },
  },
  {
    "context": "Editor",
    "unbind": {
      "ctrl-alt-right": "editor::MoveToNextSubwordEnd",
    },
  },
  {
    "context": "Terminal",
    "unbind": {
      "ctrl-alt-right": "pane::SplitRight",
    },
  },
  {
    "context": "Terminal",
    "unbind": {
      "ctrl-alt-left": "pane::SplitLeft",
    },
  },
  {
    "context": "Editor",
    "unbind": {
      "ctrl-alt-left": "editor::MoveToPreviousSubwordStart",
    },
  },
  {
    "context": "Editor && edit_prediction",
    "unbind": {
      "alt-tab": "editor::AcceptEditPrediction",
      // "tab": "editor::AcceptEditPrediction",
    },
    "bindings": {
      "alt-space": "editor::AcceptEditPrediction",
    },
  },
  {
    "context": "VimControl && !menu && vim_mode != operator",
    "bindings": {
      "w": "vim::NextSubwordStart",
      "b": "vim::PreviousSubwordStart",
      "e": "vim::NextSubwordEnd",
      "g e": "vim::PreviousSubwordEnd",
    },
  },
  {
    "bindings": {
      "cmd-shift-enter": "workspace::ToggleZoom",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "cmd-alt-g o": "editor::OpenPermalinkToLine",
      "cmd-alt-g c": "editor::CopyPermalinkToLine",
      "cmd-alt-r": "editor::ReloadFile",
    },
  },
  {
    // Surround a custom visual selection (vim-surround). Normal-mode `ys`
    // already works via the built-in `vim_operator == y` binding; this adds
    // the visual-mode path. `shift-s` keeps visual substitute on plain `s`.
    "context": "vim_mode == visual",
    "bindings": {
      "shift-s": "vim::PushAddSurrounds",
    },
  },

  // Open files in project from diff.
  {
    "context": "CommitDiff",
    "bindings": {
      "shift-g space": "git::OpenFileAtHead",
    },
  },
  {
    "context": "CommitDiff > Editor && vim_mode == insert",
    "bindings": {
      "alt-shift-enter": "git::OpenFileAtHead",
    },
  },
  {
    "context": "Editor && mode == full",
    "bindings": {
      "cmd-<": "agent::AddSelectionToThread",
    },
  },
  {
    "context": "Editor && mode == full",
    "unbind": {
      "cmd->": "agent::AddSelectionToThread",
    },
  },
  {
    "context": "AcpThread",
    "bindings": {
      "cmd-<": "agent::AddSelectionToThread",
    },
  },
  {
    "context": "AcpThread",
    "unbind": {
      "cmd->": "agent::AddSelectionToThread",
    },
  },
  {
    "context": "Terminal",
    "bindings": {
      "cmd-<": "agent::AddSelectionToThread",
    },
  },
  {
    "context": "Terminal",
    "unbind": {
      "cmd->": "agent::AddSelectionToThread",
    },
  },
  {
    "context": "Editor",
    "unbind": {
      "cmd-;": "editor::ToggleLineNumbers",
    },
  },
]
