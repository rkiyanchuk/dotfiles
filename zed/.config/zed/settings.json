// Zed documentation: https://zed.dev/docs/configuring-zed
{
  "active_pane_modifiers": {
    "inactive_opacity": 0.8,
  },
  "agent": {
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "gpt-5.5",
    },
    "commit_message_model": {
      "provider": "google",
      "model": "gemini-2.5-flash",
    },
    "commit_message_instructions": "Use scope-prefixed subjects (Linux/Git/Go style), NEVER Conventional Commits (no feat:/fix:/chore:). Format: `scope: imperative description`, where scope is the natural area touched (subsystem, package, module, dir); omit scope only for genuinely cross-cutting changes. Subject must be <= 50 chars, imperative mood, capitalized, no trailing period. For non-trivial changes add one blank line then a body wrapped at 72 columns that explains what and why, not how.",
    "default_view": "text_thread",
    "dock": "left",
    "message_editor_min_lines": 3,
    "play_sound_when_agent_done": "when_hidden",
    "show_turn_stats": true,
    "terminal_init_command": "claude --continue",
  },
  "agent_buffer_font_size": 16.0,
  "agent_servers": {
    "github-copilot-cli": {
      "default_config_options": {
        "allow_all": "on",
      },
      "type": "registry",
    },
    "claude-acp": {
      "type": "registry",
    },
    "codex-acp": {
      "favorite_config_option_values": {
        "model": ["gpt-5.5"],
      },
      "type": "registry",
    },
    "gemini": {
      "type": "registry",
    },
  },
  "agent_ui_font_size": 17.0,
  "auto_signature_help": false,
  "buffer_font_family": "Iosevka Nerd Font",
  "buffer_font_size": 16.0,
  "buffer_font_weight": 200.0,
  "buffer_line_height": {
    "custom": 1.55,
  },
  "cli_default_open_behavior": "new_window",
  "close_on_file_delete": true,
  "code_lens": "menu",
  "collaboration_panel": {
    "default_width": 300.0,
    "dock": "right",
  },
  "colorize_brackets": true,
  "confirm_quit": true,
  "current_line_highlight": "line",
  "cursor_shape": "bar",
  "debugger": {
    "dock": "bottom",
  },
  "diff_view_style": "unified",
  "document_folding_ranges": "off",
  "edit_predictions": {
    "ollama": {
      "model": "qwen2.5-coder:7b-base",
    },
    "allow_data_collection": "yes",
    "provider": "copilot",
  },
  "fast_scroll_sensitivity": 3.0,
  "git": {
    "inline_blame": {
      "delay_ms": 0,
      "enabled": false,
      "location":"status_bar",
      "show_commit_summary": false,
    },
  },
  "git_commit_buffer_font_size": 14.0,
  "git_panel": {
    "dock": "right",
  },
  "icon_theme": "Zed (Default)",
  "indent_guides": {
    "background_coloring": "disabled",
    "coloring": "fixed",
    "enabled": true,
  },
  "inlay_hints": {
    "show_background": true,
  },
  "inline_code_actions": false,
  "languages": {
    "JSON": {
      "tab_size": 2,
    },
    "YAML": {
      "tab_size": 2,
    },
    "JSONC": {
      "tab_size": 2,
    },
    "JSON5": {
      "tab_size": 2,
    },
    "Markdown": {
      "format_on_save": "on",
      "formatter": "prettier",
      "preferred_line_length": 80,
      "remove_trailing_whitespace_on_save": true,
      "soft_wrap": "bounded",
      "prettier": {
        "proseWrap": "always",
        "printWidth": 80,
      },
    },
    "Python": {
      "show_edit_predictions": true,
    },
  },
  "markdown_preview_code_font_family": "Iosevka Nerd Font",
  "markdown_preview_font_family": "IBM Plex Sans Light",
  "markdown_preview_font_size": 17,
  "middle_click_paste": false,
  "minimap": {
    "show": "never",
    "thumb": "always",
  },
  "modeline_lines": 3,
  "mouse_wheel_zoom": false,
  "outline_panel": {
    "dock": "right",
  },
  "preferred_line_length": 100,
  "profiles": {
    "Presenting": {
      "settings": {
        "agent_buffer_font_size": 18.0,
        "buffer_font_size": 18.0,
        "ui_font_size": 18.0,
      },
    },
  },
  "project_panel": {
    "button": true,
    "default_width": 300.0,
    "dock": "left",
    "git_status_indicator": false,
    "hide_root": true,
  },
  "redact_private_values": false,
  "restore_on_startup": "launchpad",
  "scroll_beyond_last_line": "vertical_scroll_margin",
  "scrollbar": {
    "axes": {
      "horizontal": true,
      "vertical": true,
    },
    "cursors": false,
    "show": "system",
  },
  "search": {
    "case_sensitive": false,
    "center_on_match": true,
  },
  "seed_search_query_from_cursor": "selection",
  "semantic_tokens": "off",
  "show_edit_predictions": true,
  "show_signature_help_after_edits": false,
  "show_wrap_guides": true,
  "soft_wrap": "editor_width",
  "status_bar": {
    "active_encoding_button": "non_utf8",
    "active_language_button": true,
    "cursor_position_button": true,
    "show_active_file": false,
  },
  "sticky_scroll": {
    "enabled": false,
  },
  "tab_bar": {
    "show": true,
    "show_nav_history_buttons": false,
    "show_pinned_tabs_in_separate_row": false,
    "show_tab_bar_buttons": false,
  },
  "tab_size": 4,
  "tabs": {
    "file_icons": false,
    "git_status": true,
    "show_diagnostics": "off",
  },
  "terminal": {
    "bell": "system",
    "button": true,
    "dock": "bottom",
    "env": {
      "EDITOR": "zed --wait",
      "VISUAL": "zed --wait",
    },
    "font_family": "IosevkaTerm Nerd Font",
    "font_size": 16.0,
    "font_weight": 250.0,
    "line_height": {
      "custom": 1.55,
    },
    "scrollbar": {
      "show": "auto",
    },
    "toolbar": {
      "breadcrumbs": false,
    },
  },
  "theme": {
    "dark": "One Dark",
    "light": "One Light",
    "mode": "dark",
  },
  "theme_overrides": {
    "One Dark": {
      // Backgrounds anchored to Ghostty's #21252A and shifted in OkLab so
      // each surface preserves its original One Dark contrast against the
      // editor base (#282c33 -> #21252a). Foreground tokens (borders, text,
      // icons, line numbers) are shifted by the same dL (-0.030) as the
      // editor base so each preserves its original contrast against it.
      "background": "#282d35ff",
      "border": "#3e434fff",
      "border.disabled": "#393f4cff",
      "border.selected": "#2c313aff",
      "border.variant": "#2e343eff",
      "editor.active_line.background": "#282d35bf",
      "editor.active_line_number": "#c6cad0ff",
      "editor.background": "#21252aff",
      "editor.gutter.background": "#21252aff",
      "editor.highlighted_line.background": "#282d35ff",
      "editor.line_number": "#465257ff",
      "editor.subheader.background": "#282d35ff",
      "element.active": "#3d424cff",
      "element.background": "#272d35ff",
      "element.hover": "#2f353dff",
      "element.selected": "#3d424cff",
      "elevated_surface.background": "#282d35ff",
      "ghost_element.active": "#3d424cff",
      "ghost_element.hover": "#2f353dff",
      "ghost_element.selected": "#3d424cff",
      "icon": "#d2d6dbff",
      "icon.disabled": "#7e818fff",
      "icon.muted": "#a0a6b3ff",
      "panel.background": "#282d35ff",
      "scrollbar.thumb.background": "#bec2ca4c",
      "scrollbar.thumb.border": "#2e343eff",
      "scrollbar.thumb.hover_background": "#2f353dff",
      "scrollbar.track.border": "#272b34ff",
      "status_bar.background": "#2c313aff",
      "surface.background": "#282d35ff",
      "tab.active_background": "#21252aff",
      "tab.inactive_background": "#282d35ff",
      "tab_bar.background": "#282d35ff",
      "terminal.background": "#21252aff",
      "text": "#d2d6dbff",
      "text.disabled": "#7e818fff",
      "text.muted": "#a0a6b3ff",
      "text.placeholder": "#7e818fff",
      "title_bar.background": "#2c313aff",
      "title_bar.inactive_background": "#272d35ff",
      "toolbar.background": "#21252aff",
      "syntax": {
        "comment": { "font_style": "italic" },
      },
    },
  },
  "title_bar": {
    "button_layout": "platform_default",
    "show_branch_status_icon": true,
    "show_onboarding_banner": true,
    "show_project_items": true,
    "show_sign_in": false,
    "show_user_menu": true,
    "show_user_picture": false,
  },
  "toolbar": {
    "code_actions": true,
    "quick_actions": true,
    "selections_menu": true,
  },
  "ui_font_family": ".SystemUIFont",
  "ui_font_size": 16.0,
  "ui_font_weight": 300.0,
  "use_smartcase_search": true,
  "vertical_scroll_margin": 3.0,
  "vim": {
    "cursor_shape": {
      "visual": "hollow",
    },
    "gdefault": false,
    "use_smartcase_find": true,
  },
  "vim_mode": true,
  "which_key": {
    "delay_ms": 500,
    "enabled": true,
  },
}
