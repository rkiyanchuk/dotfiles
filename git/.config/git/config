[gpg]
    format = ssh

[gpg "ssh"]
    allowedSignersFile = ~/.ssh/allowed_signers
    program = ssh-keygen

[core]
    precomposeUnicode = true
    editor = nvim

[init]
    defaultBranch = main

[commit]
    gpgsign = true

[credential "https://github.com"]
    helper = !/opt/homebrew/bin/gh auth git-credential

[credential "https://gist.github.com"]
    helper = !/opt/homebrew/bin/gh auth git-credential

[apply]
    whitespace = warn

[help]
    autocorrect = prompt

[diff]
    tool = nvimdiff
    guitool = zed
    algorithm = histogram
    colorMoved = default

[merge]
    tool = nvimdiff
    guitool = zed

[mergetool]
    keepBackup = false

[mergetool "nvim"]
  cmd = nvim -d $LOCAL $REMOTE $MERGED -c '$wincmd w' -c 'wincmd J'

[mergetool "vscode"]
    cmd = code --wait $MERGED

[mergetool "zed"]
    cmd = zed --wait $MERGED

[difftool "vscode"]
    cmd = code --wait --diff $LOCAL $REMOTE

[difftool "zed"]
    cmd = zed --wait --diff $LOCAL $REMOTE

[log]
    date = iso

[fetch]
    prune = true

[pull]
    ff = only

[push]
    default = current
    autoSetupRemote = true
    followTags = true

[rebase]
    autoStash = true
    updateRefs = true

[column]
    ui = auto

[filter "lfs"]
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
    required = true

[rerere]
    enabled = true

[alias]
    st = status -sb
    br = branch -vv
    bra = branch -avv
    cm = commit
    co = checkout
    sw = switch
    dc = diff --cached
    ds = diff --stat
    ls = ls-files
    mt = mergetool
    uncommit = reset --soft HEAD^
    authors = shortlog -sne

    # Rank authors by numbers of commits (don't do it!)
    contributors = shortlog -sne --group=author --group=trailer:co-authored-by

    hist = log --graph --decorate --date=short --pretty=format:\"%C(blue)%h%Creset %C(dim white)%ad%Creset %s  %C(green)%an%Creset %C(cyan)%d%Creset\"
    hist-signed = log --graph --decorate --date=short --pretty=format:\"%C(blue)%h%Creset %C(dim white)%ad%Creset %C(red)%G?%Creset %s  %C(green)%an%Creset %C(yellow)%GK%Creset %C(cyan)%d%Creset\"
    rebase-sign = rebase --exec 'git commit --amend --no-edit -n -S'

    prune-local = !bash -c 'git branch --format \"%(upstream:track)%(refname)\" | grep \"^\\[gone\\]\" | cut -c 18- | xargs git branch -D'

    # Delete a branch locally and on origin in one go.
    delete-branch = "!f() { git branch -D \"$1\" && git push origin --delete \"$1\"; }; f"

    # Repo overview: project, age, commits, files, ranked authors with %.
    summary = "!f() { \
        echo \"project : $(basename \"$(git rev-parse --show-toplevel)\")\"; \
        echo \"age     : $(git log --reverse --format=%cr | sed -n 1p)\"; \
        echo \"commits : $(git rev-list --count HEAD)\"; \
        echo \"files   : $(git ls-files | wc -l | tr -d ' ')\"; \
        echo \"authors :\"; \
        git shortlog -sne HEAD | awk '{n=$1; sub(/^[ ]*[0-9]+[ \\t]+/, \"\"); a[NR]=$0; v[NR]=n; t+=n} END {for (i=1; i<=NR; i++) printf \"  %5.1f%%  %s\\n\", v[i]/t*100, a[i]}'; \
    }; f"

    # Top 20 most-changed files in the last year (high churn = potential risk).
    stats-hotfiles = !git log --format=format: --name-only --since='1 year ago' | sort | uniq -c | sort -nr | head -20

    # Commit activity grouped by month.
    stats-activity = !git log --format='%ad' --date=format:'%Y-%m' | sort | uniq -c

    # Reverts, hotfixes, and emergency patches in the last year.
    stats-hotfixes = !git log --graph --decorate --date=short --pretty=format:\"%C(blue)%h%Creset %C(dim white)%ad%Creset %s  %C(green)%an%Creset %C(cyan)%d%Creset\" --since='1 year ago' --grep='revert' --grep='hotfix' --grep='emergency' --grep='rollback' -i

    # Top 20 files most frequently appearing in bug-fix commits.
    stats-bugs = !git log -i --grep='fix' --grep='bug' --grep='broken' --name-only --format='' | sort | uniq -c | sort -nr | head -20

    # Recursively pull and update all branches in all repos in current dir.
    rpull = "! ~/.config/git/recursive-sync.py"

    # Recursively show commits since a date (default: yesterday) in all repos.
    rhist = "! ~/.config/git/recursive-hist.py"

[includeIf "gitdir:~/"]
    path = ~/.config/git/config.local

[includeIf "gitdir:~/workspace/"]
    path = ~/.config/git/config.workspace.local
