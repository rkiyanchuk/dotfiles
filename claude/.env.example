# Copy this file to claude/.env and fill in real values.
# claude/.env is gitignored — secrets stay on this machine.

# Discord MCP (github.com/elyxlz/discord-mcp)
DISCORD_EMAIL=your_email@example.com
DISCORD_PASSWORD=your_password

# Nano Banana — Google AI Studio API key for Gemini
GEMINI_API_KEY=

# LightRAG MCP — base URL for the local lightrag server
LIGHTRAG_BASE_URL=http://localhost:9621
