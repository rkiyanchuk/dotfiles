{
  "env": {
    "DISABLE_NON_ESSENTIAL_MODEL_CALLS": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Read",
      "WebFetch",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:just.systems)",
      "WebSearch",
      "mcp__github__get_file_contents",
      "mcp__github__get_me",
      "mcp__github__get_pull_request",
      "mcp__github__get_repo",
      "mcp__github__search_code",
      "mcp__github__search_pull_requests",
      "mcp__new-relic__list_dashboards",
      "mcp__new-relic__nrql_query",
      "mcp__new-relic__search_entities",
      "mcp__plugin_context7_context7__query-docs",
      "mcp__plugin_context7_context7__resolve-library-id"
    ],
    "defaultMode": "default",
    "additionalDirectories": [
      "/Users/ruslan/Library/Mobile Documents/iCloud~md~obsidian/Documents/notes"
    ]
  },
  "model": "opusplan",
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": false,
    "lua-lsp@claude-plugins-official": false,
    "pr-review-toolkit@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": false,
    "rust-analyzer-lsp@claude-plugins-official": false,
    "swift-lsp@claude-plugins-official": false,
    "typescript-lsp@claude-plugins-official": false,
    "obsidian@obsidian-skills": true,
    "firecrawl@claude-plugins-official": false,
    "skill-creator@claude-plugins-official": false
  },
  "extraKnownMarketplaces": {
    "obsidian-skills": {
      "source": {
        "source": "github",
        "repo": "kepano/obsidian-skills"
      }
    },
    "trailofbits": {
      "source": {
        "source": "github",
        "repo": "trailofbits/skills"
      }
    }
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "filesystem": {
      "allowWrite": [
        "//tmp/build",
        "/Users/ruslan/Library/Mobile Documents/iCloud~md~obsidian/Documents/notes"
      ]
    }
  },
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Processing"
    ]
  },
  "autoUpdatesChannel": "latest",
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "voiceEnabled": true,
  "remoteControlAtStartup": false,
  "agentPushNotifEnabled": true
}
