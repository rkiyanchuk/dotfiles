{
  "agentPushNotifEnabled": true,
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "autoUpdatesChannel": "latest",
  "cleanupPeriodDays": 90,
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": false,
    "lua-lsp@claude-plugins-official": false,
    "obsidian@obsidian-skills": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": false,
    "rust-analyzer-lsp@claude-plugins-official": false,
    "skill-creator@claude-plugins-official": false,
    "swift-lsp@claude-plugins-official": false,
    "typescript-lsp@claude-plugins-official": false
  },
  "env": {
    "DISABLE_NON_ESSENTIAL_MODEL_CALLS": "1"
  },
  "extraKnownMarketplaces": {
    "obsidian-skills": {
      "source": {
        "repo": "kepano/obsidian-skills",
        "source": "github"
      }
    },
    "trailofbits": {
      "source": {
        "repo": "trailofbits/skills",
        "source": "github"
      }
    }
  },
  "hooks": {
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "bash ~/.claude/hooks/normalize-settings.sh",
            "type": "command"
          }
        ]
      }
    ]
  },
  "permissions": {
    "additionalDirectories": [
      "/Users/ruslan/Library/Mobile Documents/iCloud~md~obsidian/Documents/Profession",
      "/Users/ruslan/Library/Mobile Documents/iCloud~md~obsidian/Documents/Notes"
    ],
    "allow": [
      "Read",
      "WebFetch",
      "WebSearch",
      "WebFetch(domain:api.github.com)",
      "mcp__github__get_file_contents",
      "mcp__github__get_me",
      "mcp__github__get_pull_request",
      "mcp__github__get_repo",
      "mcp__github__search_code",
      "mcp__github__search_pull_requests",
      "WebFetch(domain:just.systems)"
    ],
    "defaultMode": "default"
  },
  "remoteControlAtStartup": false,
  "sandbox": {
    "autoAllowBashIfSandboxed": true,
    "enabled": true,
    "filesystem": {
      "allowWrite": [
        "//tmp/build",
        "/Users/ruslan/Library/Mobile Documents/iCloud~md~obsidian/Documents/Profession",
        "/Users/ruslan/Library/Mobile Documents/iCloud~md~obsidian/Documents/Notes"
      ]
    }
  },
  "skillListingBudgetFraction": 0.02,
  "skipAutoPermissionPrompt": true,
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Processing"
    ]
  },
  "statusLine": {
    "command": "bash ~/.claude/statusline.sh",
    "type": "command"
  },
  "theme": "auto",
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "voiceEnabled": true
}
