#!/usr/bin/env bash
# claude-resume — resume any Claude Code session.
#
# Claude keys resumable sessions by cwd: transcripts live at
#   ~/.claude/projects/<encoded-cwd>/<session-id>.jsonl
# and `claude --resume <id>` only scans the project dir for the current cwd,
# with no flag to point it elsewhere.
#
# Default: cd into the session's original directory and resume it there — the
# transcript already lives in the project dir keyed to that cwd, so no copy or
# rewrite is needed.
#
# ctrl-o: *move* the session into the dir you're standing in (relocate the
# transcript into the current cwd's project dir, rewriting the recorded `cwd`
# so the "from a different directory" banner stays quiet, and delete the
# original), then resume it in place.

set -euo pipefail

PROJECTS_DIR="${CLAUDE_CONFIG_DIR:-$HOME/.claude}/projects"

die() { printf 'claude-resume: %s\n' "$1" >&2; exit 1; }

# Hidden subcommand: render the fzf preview for one transcript. Invoked by fzf
# itself (`claude-resume --preview-file <path>`) so it always runs under this
# bash script, never the user's interactive shell (e.g. fish).
if [ "${1-}" = "--preview-file" ]; then
  p="${2-}"
  [ -f "$p" ] || exit 0
  python3 - "$p" <<'PY'
import json, os, sys, time

path = sys.argv[1]
title = cwd = branch = model = first = first_ts = last_ts = None
user_msgs = asst_msgs = 0

def text_of(content):
    if isinstance(content, str):
        return content
    if isinstance(content, list):
        for part in content:
            if isinstance(part, dict) and part.get("type") == "text":
                return part.get("text")
    return None

for line in open(path, errors="replace"):
    try:
        obj = json.loads(line)
    except ValueError:
        continue
    if not isinstance(obj, dict):
        continue
    if title is None and obj.get("aiTitle"):
        title = obj["aiTitle"]
    if cwd is None and obj.get("cwd"):
        cwd = obj["cwd"]
    if branch is None and obj.get("gitBranch"):
        branch = obj["gitBranch"]
    ts = obj.get("timestamp")
    if ts:
        first_ts = first_ts or ts
        last_ts = ts
    msg = obj.get("message")
    if isinstance(msg, dict):
        role = msg.get("role")
        if role == "user":
            user_msgs += 1
            if first is None:
                first = text_of(msg.get("content"))
        elif role == "assistant":
            asst_msgs += 1
            if model is None and msg.get("model"):
                model = msg["model"]

# ANSI palette
B   = "\033[1m"        # bold
DIM = "\033[2m"        # dim
R   = "\033[0m"        # reset
CYA = "\033[36m"       # labels
GRN = "\033[32m"
YEL = "\033[33m"
MAG = "\033[35m"
BLU = "\033[34m"

def parse_ts(s):
    if not s:
        return None
    try:
        return time.strptime(s[:19], "%Y-%m-%dT%H:%M:%S")
    except (ValueError, TypeError):
        return None

def fmt_ts(s):
    t = parse_ts(s)
    return time.strftime("%Y-%m-%d %H:%M", t) if t else "?"

def label(name, value, color=GRN):
    print("%s%-9s%s %s%s%s" % (CYA, name, R, color, value, R))

print("%s%s%s" % (B, (title or "(untitled session)"), R))
print("%s%s%s" % (DIM, "─" * 56, R))
if model:
    label("model", model, MAG)
label("started", fmt_ts(first_ts), BLU)
label("updated", fmt_ts(last_ts), BLU)
label("messages", "%d user · %d assistant" % (user_msgs, asst_msgs), GRN)
label("file", os.path.basename(path), DIM)
print()
print("%sFirst user prompt%s" % (DIM, R))
print("%s%s%s" % (DIM, "─" * 56, R))
print((first or "(none)").strip()[:1000])
PY
  exit 0
fi

# Hidden subcommand: delete a transcript file (bound to ctrl-x in the picker).
if [ "${1-}" = "--delete-file" ]; then
  p="${2-}"
  [ -n "$p" ] && [ -f "$p" ] && rm -f "$p"
  exit 0
fi

# Hidden subcommand: emit the NUL-delimited fzf records. Split out so the
# picker can re-run it via fzf's reload() after a delete.
if [ "${1-}" = "--list" ]; then
  # claude-mem's background "observer" sessions live in one fixed project dir
  # (keyed to ~/.claude-mem/observer-sessions) and are never meant to be
  # resumed by a human — exclude that whole dir rather than trying to
  # detect them by title or message count (both are inconsistent: most have
  # real turns logged, and many even get an aiTitle).
  exclude_dir="$(printf '%s' "$HOME/.claude-mem/observer-sessions" | sed 's/[^a-zA-Z0-9]/-/g')"
  python3 - "${2-}" "$exclude_dir" <<'PY'
import glob, json, os, sys, time

root = sys.argv[1]
exclude_dir = sys.argv[2]
DIM, RESET = "\033[2m", "\033[0m"
HOME = os.path.expanduser("~")

def tilde(p):
    if p == HOME:
        return "~"
    if p.startswith(HOME + os.sep):
        return "~" + p[len(HOME):]
    return p

def rel_time(secs):
    d = max(0, time.time() - secs)
    for n, unit in ((86400*365,"year"),(86400*30,"month"),(86400*7,"week"),
                    (86400,"day"),(3600,"hour"),(60,"minute")):
        if d >= n:
            v = int(d // n)
            return "%d %s%s ago" % (v, unit, "" if v == 1 else "s")
    return "just now"

def human_size(n):
    for unit in ("B","KB","MB","GB"):
        if n < 1024 or unit == "GB":
            return ("%d %s" % (n, unit)) if unit == "B" else ("%.1f%s" % (n, unit))
        n /= 1024.0

rows = []
for path in glob.glob(os.path.join(root, "*", "*.jsonl")):
    if os.path.basename(os.path.dirname(path)) == exclude_dir:
        continue
    try:
        st = os.stat(path)
    except OSError:
        continue
    sid = os.path.basename(path)[:-6]  # strip .jsonl
    title = cwd = branch = ""
    try:
        with open(path, errors="replace") as fh:
            for line in fh:
                try:
                    obj = json.loads(line)
                except ValueError:
                    continue
                if not isinstance(obj, dict):
                    continue
                if not title and obj.get("aiTitle"):
                    title = obj["aiTitle"]
                if not cwd and obj.get("cwd"):
                    cwd = obj["cwd"]
                if not branch and obj.get("gitBranch"):
                    branch = obj["gitBranch"]
                if title and cwd and branch:
                    break
    except OSError:
        pass
    rows.append((st.st_mtime, sid, path, title, cwd, branch, st.st_size))

rows.sort(reverse=True)
for mtime, sid, path, title, cwd, branch, size in rows:
    meta = [rel_time(mtime)]
    if branch:
        meta.append(branch)
    meta.append(human_size(size))
    if cwd:
        meta.append(tilde(cwd))
    display = "%s\n%s%s%s" % (title or "(untitled session)",
                              DIM, "  ·  ".join(meta), RESET)
    sys.stdout.write("\t".join((display, sid, path)) + "\0")
PY
  exit 0
fi

[ -d "$PROJECTS_DIR" ] || die "no projects dir at $PROJECTS_DIR"

# encode a path the way Claude names project dirs: non-alphanumerics -> '-'
encode_cwd() { printf '%s' "$1" | sed 's/[^a-zA-Z0-9]/-/g'; }

session_id="${1-}"
# strip the id off the arg list; remaining args pass through to `claude`.
[ "$#" -gt 0 ] && shift || true

# --- pick a session interactively when no id was given --------------------
if [ -z "$session_id" ]; then
  command -v fzf >/dev/null 2>&1 || die "no session id given and fzf not found"

  # Records are built by the hidden `--list` subcommand: NUL-delimited,
  # two-line entries  <display>\t<id>\t<path>  where <display> is the AI title
  # plus a dim metadata line (relative time · branch · size · cwd), matching
  # the built-in `claude --resume` picker. ctrl-x deletes the highlighted
  # transcript and reloads the list. Enter resumes in the session's original
  # dir (cd, no copy); ctrl-o *moves* the session into the current dir — both
  # surfaced via --expect, which prints the pressed key as the first output line.
  self="$0"
  pick="$(
    "$self" --list "$PROJECTS_DIR" | fzf --read0 --gap --ansi \
        --layout=reverse \
        --delimiter='\t' --with-nth=1 --accept-nth=2,3 \
        --expect=ctrl-o \
        --list-border=rounded \
        --list-label=' ctrl-x: delete  ·  ctrl-o: open in current dir ' \
        --list-label-pos='-3:bottom' \
        --color='list-label:dim' \
        --preview-window='down,45%,wrap' \
        --preview "'$self' --preview-file {3}" \
        --bind "ctrl-x:execute-silent('$self' --delete-file {3})+reload('$self' --list '$PROJECTS_DIR')"
  )" || die "no session selected"

  # --expect prints the key on line 1 (empty for Enter); --accept-nth=2,3
  # prints the selection as <id><TAB><path> on line 2.
  key="$(printf '%s' "$pick" | sed -n 1p)"
  sel="$(printf '%s' "$pick" | sed -n 2p)"
  session_id="$(printf '%s' "$sel" | cut -f1)"
  src="$(printf '%s' "$sel" | cut -f2)"
  [ "$key" = "ctrl-o" ] && move_to_current=1
fi

[ -n "$session_id" ] || die "empty session id"

# --- locate the source transcript anywhere under projects ----------------
if [ -z "${src-}" ]; then
  src=""
  for d in "$PROJECTS_DIR"/*/; do
    if [ -f "$d$session_id.jsonl" ]; then src="$d$session_id.jsonl"; break; fi
  done
fi
[ -n "$src" ] && [ -f "$src" ] || die "session not found: $session_id"

# --- ctrl-o: move the session into the CURRENT cwd's project dir ---------
# Relocate the transcript into the project dir keyed to the dir we're standing
# in (rewriting the recorded cwd so the "from a different directory" banner
# stays quiet), delete the original, then resume in place.
if [ -n "${move_to_current-}" ]; then
  target="$PROJECTS_DIR/$(encode_cwd "$PWD")"
  mkdir -p "$target"
  dst="$target/$session_id.jsonl"

  relocate_with_cwd_rewrite() {
    # rewrite the recorded cwd on every line so the banner stays quiet.
    if command -v jq >/dev/null 2>&1 \
       && jq -e . "$src" >/dev/null 2>&1; then
      jq -c --arg d "$PWD" 'if has("cwd") then .cwd=$d else . end' \
        "$src" >"$dst.tmp"
    else
      python3 - "$src" "$dst.tmp" "$PWD" <<'PY'
import json, sys
src, dst, cwd = sys.argv[1], sys.argv[2], sys.argv[3]
with open(src) as fh, open(dst, "w") as out:
    for line in fh:
        s = line.strip()
        if not s:
            continue
        try:
            obj = json.loads(s)
        except ValueError:
            out.write(line if line.endswith("\n") else line + "\n")
            continue
        if isinstance(obj, dict) and "cwd" in obj:
            obj["cwd"] = cwd
        out.write(json.dumps(obj) + "\n")
PY
    fi
    mv "$dst.tmp" "$dst"
  }

  if [ "$src" = "$dst" ]; then
    : # already lives here; resume as-is
  else
    relocate_with_cwd_rewrite
    rm -f "$src"
    printf 'claude-resume: moved session %s into %s\n' "$session_id" "$PWD" >&2
  fi

  exec claude --resume "$session_id" "$@"
fi

# --- default: cd into the session's original dir and resume there --------
# The transcript already lives in its own project dir keyed to its original
# cwd, so `claude --resume` finds it natively once we cd there.
orig="$(python3 - "$src" <<'PY'
import json, sys
for line in open(sys.argv[1], errors="replace"):
    try:
        obj = json.loads(line)
    except ValueError:
        continue
    if isinstance(obj, dict) and obj.get("cwd"):
        print(obj["cwd"]); break
PY
)"
[ -n "$orig" ] && [ -d "$orig" ] || die "original dir not found for $session_id"
cd "$orig" || die "cannot cd to $orig"
exec claude --resume "$session_id" "$@"
